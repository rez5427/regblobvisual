[Unit]
Description=RegBlobVisual frontend (Vite preview)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/regblobvisual/ui
Environment=NODE_ENV=production
ExecStart=/bin/bash -lc 'npm run preview -- --host 0.0.0.0 --port 4173'
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
